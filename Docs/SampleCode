/**

* @source Architecture Blueprint

* @source Architectural Knowledge Base

* @source Product Guide Knowledge Base

* @requirement FR-EntityManagement

* @acceptanceCriteria AC-EntityDefinition

*/

import { Injectable, inject } from '@angular/core';

import { HttpClient } from '@angular/common/http';

import { RiskEntity, CreateEntityRequest, UpdateEntityRequest, EntityResponse } from '../models/risk-entity.model';

import { Observable, catchError, retry } from 'rxjs';
 
@Injectable({ providedIn: 'root' })

export class RiskEntityService {

  private http = inject(HttpClient);

  private baseUrl = '/api/risk-entities';
 
  getEntities(): Observable<EntityResponse[]> {

    return this.http.get<EntityResponse[]>(this.baseUrl).pipe(

      retry(2),

      catchError(this.handleError)

    );

  }
 
  getEntity(id: string): Observable<EntityResponse> {

    return this.http.get<EntityResponse>(`${this.baseUrl}/${id}`).pipe(

      retry(2),

      catchError(this.handleError)

    );

  }
 
  createEntity(payload: CreateEntityRequest): Observable<EntityResponse> {

    return this.http.post<EntityResponse>(this.baseUrl, payload).pipe(

      catchError(this.handleError)

    );

  }
 
  updateEntity(id: string, payload: UpdateEntityRequest): Observable<EntityResponse> {

    return this.http.put<EntityResponse>(`${this.baseUrl}/${id}`, payload).pipe(

      catchError(this.handleError)

    );

  }
 
  deleteEntity(id: string): Observable<void> {

    return this.http.delete<void>(`${this.baseUrl}/${id}`).pipe(

      catchError(this.handleError)

    );

  }
 
  private handleError(error: any) {

    // TODO: Implement error handling and logging

    throw error;

  }

}

