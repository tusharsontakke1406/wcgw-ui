/**

* @source Architecture Blueprint

* @source Architectural Knowledge Base

* @source Product Guide Knowledge Base

* @requirement FR-EntityManagement

* @acceptanceCriteria AC-EntityList

*/

import { Component, signal, computed, effect } from '@angular/core';

import { RiskEntityService } from '../../../../core/services/risk-entity.service';

import { RiskEntity } from '../../../../core/models/risk-entity.model';
 
@Component({

  selector: 'app-entity-list',

  standalone: true,

  templateUrl: './entity-list.component.html',

  styleUrls: ['./entity-list.component.scss']

})

export class EntityListComponent {

  private riskEntityService = inject(RiskEntityService);

  entities = signal<RiskEntity[]>([]);

  loading = signal<boolean>(true);

  error = signal<string | null>(null);
 
  constructor() {

    effect(() => {

      this.riskEntityService.getEntities().subscribe({

        next: (data) => {

          this.entities.set(data);

          this.loading.set(false);

        },

        error: (err) => {

          this.error.set(err.message);

          this.loading.set(false);

        }

      });

    });

  }

}

